# Copy to .env.local for local dev, and add these in Vercel → Settings → Environment Variables for production.

# Required — get one free at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — where quote requests are delivered
TO_EMAIL=mike@forgecleaningandpropertyservices.com

# Optional — verified sender. The default onboarding@resend.dev works out of the box
# as long as TO_EMAIL matches the email you signed up to Resend with.
# After verifying the domain in Resend, change this to e.g. quotes@forgecleaningandpropertyservices.com
FROM_EMAIL=Forge Website <onboarding@resend.dev>
